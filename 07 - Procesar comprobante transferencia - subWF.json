    {
      "parameters": {
        "jsCode": "// Parsear la respuesta de la IA\nconst respuesta = $input.item.json.text || $input.item.json.content || '';\nlet datos = {};\ntry {\n  // Limpiar posibles backticks de markdown\n  const clean = respuesta.replace(/```json|```/g, '').trim();\n  datos = JSON.parse(clean);\n} catch(e) {\n  datos = { error: 'No se pudo parsear la respuesta', raw: respuesta };\n}\n\nreturn {\n  ...datos,\n  chat_id: $('When Executed by Another Workflow').item.json.chat_id,\n  baserow_row_id: $('When Executed by Another Workflow').item.json.baserow_row_id,\n  cancha_final: $('When Executed by Another Workflow').item.json.cancha_final,\n  fecha_hora_iso_start: $('When Executed by Another Workflow').item.json.fecha_hora_iso_start,\n  fecha_hora_iso_end: $('When Executed by Another Workflow').item.json.fecha_hora_iso_end,\n  nombre: $('When Executed by Another Workflow').item.json.nombre,\n  monto_esperado: $('When Executed by Another Workflow').item.json.monto,\n  fecha_formateada: $('When Executed by Another Workflow').item.json.fecha_formateada,\n  hora_formateada: $('When Executed by Another Workflow').item.json.hora_formateada,\n  client_id: $('When Executed by Another Workflow').item.json.client_id\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
