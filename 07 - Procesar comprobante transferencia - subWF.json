        "url": "https://api.mercadopago.com/v1/payments/search?sort=date_created&criteria=desc&limit=20",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
