      "id": "42f0fe65-9191-45e2-8f62-d1bbdad2310f",
      "name": "Consultar pagos recientes MP",
      "credentials": {
        "httpBearerAuth": {
          "id": "XQIv9rwLJIxyRxtp",
          "name": "MercadoPago-Bearer"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Comparar número de comprobante del archivo con pagos recientes de MP\nconst datosParsed = $('Parsear datos comprobante').item.json;\nconst numeroCbte = String(datosParsed.numero_comprobante || '').toLowerCase().trim();\nconst montoCbte = parseFloat(datosParsed.monto) || 0;\nconst montoEsperado = parseFloat(datosParsed.monto_esperado) || 0;\n\nconst pagos = $input.item.json?.results || [];\n\n// Buscar coincidencia por número de comprobante o ID de operación\nlet pagoEncontrado = null;\nfor (const pago of pagos) {\n  const idPago = String(pago.id || '').toLowerCase();\n  const idOperacion = String(pago.operation_id || '').toLowerCase();\n  const externalRef = String(pago.external_reference || '').toLowerCase();\n  \n  if (\n    numeroCbte && (\n      idPago.includes(numeroCbte) || \n      numeroCbte.includes(idPago) ||\n      idOperacion.includes(numeroCbte) ||\n      externalRef.includes(numeroCbte)\n    )\n  ) {\n    pagoEncontrado = pago;\n    break;\n  }\n}\n\n// Si no encontramos por número, verificar por monto\nif (!pagoEncontrado && montoCbte > 0) {\n  pagoEncontrado = pagos.find(p => \n    parseFloat(p.transaction_amount) === montoCbte && \n    p.status === 'approved'\n  ) || null;\n}\n\nreturn {\n  ...datosParsed,\n  pago_encontrado: pagoEncontrado !== null,\n  pago_mp: pagoEncontrado,\n  monto_coincide: Math.abs(montoCbte - montoEsperado) < 10\n};"
      },
